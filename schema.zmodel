// Elmi — ZenStack v3 schema
// Run: npx zenstack generate && npx prisma migrate dev
//
// Every model MUST have @@allow / @@deny policies before shipping.
// Multi-tenant isolation is enforced here — NOT in application code.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

plugin enhancer {
  provider = "@core/enhancer"
}

// ---------------------------------------------------------------------------
// Auth models (managed by Better-Auth + ZenStack adapter)
// ---------------------------------------------------------------------------

// User, Session, Account, Verification, Organization, Member, Invitation
// are generated by the @zenstackhq/better-auth plugin — do not define manually.

// ---------------------------------------------------------------------------
// Domain models — add below
// ---------------------------------------------------------------------------
